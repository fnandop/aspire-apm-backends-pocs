{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "dotnet-route": {
        "ClusterId": "dotnet-cluster",
        "Match": {
          "Path": "/api/dotnet/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/dotnet"
          }
        ]
      },
      "node-route": {
        "ClusterId": "node-cluster",
        "Match": {
          "Path": "/api/node/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/node"
          }
        ]
      },
      "spring-route": {
        "ClusterId": "spring-cluster",
        "Match": {
          "Path": "/api/spring/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/spring"
          }
        ]
      }
    },
    "Clusters": {
      "dotnet-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://api-service"
          }
        }
      },
      "node-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://node-api"
          }
        }
      },
      "spring-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://spring-boot-api"
          }
        }
      }
    }
  }
}
